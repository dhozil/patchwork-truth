# GenLayer Configuration for Patchwork Truth
# Copy this to frontend/.env and fill in the values

# Deployed contract address (from npm run deploy)
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# GenLayer network (studionet | localnet | testnet)
GENLAYER_NETWORK=studionet

# OpenAI API key (used by the contract for LLM evaluation)
# The contract calls OpenAI internally via gl.nondet.web
OPENAI_API_KEY=sk-your-openai-key-here

# Wallet connect project ID (for RainbowKit/wagmi)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Optional: RPC URL override
# NEXT_PUBLIC_GENLAYER_RPC=https://api.genlayer.com/v1
